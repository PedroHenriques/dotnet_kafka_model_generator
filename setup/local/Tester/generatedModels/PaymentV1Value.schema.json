{
  "type": "record",
  "name": "PaymentV1Value",
  "namespace": "Test.Kafka.Events",
  "fields": [
    {
      "name": "paymentId",
      "type": "string"
    },
    {
      "name": "status",
      "type": {
        "type": "enum",
        "name": "PaymentStatus",
        "symbols": [
          "PENDING",
          "COMPLETED",
          "FAILED"
        ]
      }
    },
    {
      "name": "amount",
      "type": {
        "type": "bytes",
        "logicalType": "decimal",
        "precision": 10,
        "scale": 2
      }
    },
    {
      "name": "processedAt",
      "type": {
        "type": "long",
        "logicalType": "timestamp-millis"
      }
    },
    {
      "name": "metadata",
      "type": {
        "type": "map",
        "values": "string"
      }
    },
    {
      "name": "failureReason",
      "type": [
        "null",
        "string"
      ],
      "default": null
    },
    {
      "name": "paymentMethod",
      "type": [
        "null",
        {
          "type": "record",
          "name": "CardDetails",
          "fields": [
            {
              "name": "last4",
              "type": "string"
            },
            {
              "name": "brand",
              "type": "string"
            }
          ]
        }
      ],
      "default": null
    }
  ]
}